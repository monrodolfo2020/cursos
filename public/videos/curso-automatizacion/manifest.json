{
  "course": "Curso de Instrumentación y Automatización Industrial",
  "format": "Motion-graphics HTML videos (React 18 + Babel standalone, 1920×1080)",
  "renderer": "Each video is a self-contained HTML file. Open it directly in a browser. No build step, no server required (works over file:// and http://).",
  "convention": {
    "self_contained_modules": "Every module folder holds its own copy of animations.jsx and its theme/scene .jsx files, so a folder can be opened, moved or deployed independently of the others.",
    "module_index": "Each module folder has an index.html that links every lesson of that module and cross-links to sibling modules via ../",
    "lesson_naming": "Lesson HTML filenames encode the module: 'Clase 1.x' = Módulo 1, 'Clase 2.x' = Módulo 2, 'Clase 3.x' = Módulo 3. Módulo 0 lessons are 'Clase 2..7' + 'Video Módulo 0.html'.",
    "playhead_persistence": "Each video stores its scrubber position in localStorage under a unique key (e.g. m3c6), so courses never collide."
  },
  "shared_dependencies_per_folder": [
    "animations.jsx (timeline engine: Stage, useTime, Easing, clamp)"
  ],
