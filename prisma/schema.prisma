generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Course {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  title       String
  description String
  instructor  String
  level       String
  category    String
  totalMinutes Int
  lessonCount Int
  thumbnail   String?
  createdAt   DateTime @default(now())
  lessons     Lesson[]
}

model Lesson {
  id          Int     @id @default(autoincrement())
  courseId    Int
  course      Course  @relation(fields: [courseId], references: [id])
  order       Int
  title       String
  description String
  durationSec Int
  videoPath   String
}
